# Copy to .env and fill in. docker-compose reads this file for variable
# substitution. All values have working defaults except STEAM_API_KEY.

# --- Steam Web API ----------------------------------------------------------
# Get one at https://steamcommunity.com/dev/apikey. Leave BLANK for now: the
# stack runs without it, but vanity-URL resolution and Steam identity hydration
# stay disabled until a key is provided.
STEAM_API_KEY=

# --- Postgres ---------------------------------------------------------------
POSTGRES_USER=cs2
POSTGRES_PASSWORD=cs2
POSTGRES_DB=cs2tracker

# --- Backend (used when running services OUTSIDE docker) ---------------------
# Inside docker compose these are set per-service with the right hostnames.
# For a local run (go run ./cmd/api) point them at localhost:
#   DATABASE_URL=postgres://cs2:cs2@localhost:5432/cs2tracker?sslmode=disable
#   REDIS_URL=redis://localhost:6379/0
HTTP_ADDR=:8080
CORS_ORIGINS=http://localhost:3000
DEMO_QUEUE_KEY=cs2:demos:parse
DEMO_WORK_DIR=/tmp/cs2
DELETE_RAW_DEMO=true
JOB_TIMEOUT=10m
CACHE_TTL=5m
# Per-client-IP API rate limit. RATE_LIMIT_RPS=0 disables it.
RATE_LIMIT_RPS=10
RATE_LIMIT_BURST=20

# --- Frontend ---------------------------------------------------------------
# Where the Next.js server reaches the backend (server-to-server).
#   docker compose: http://backend:8080
#   local dev:      http://localhost:8080
API_INTERNAL_URL=http://localhost:8080
