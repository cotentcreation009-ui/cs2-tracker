# Copy to .env and fill in. docker-compose reads this file for variable
# substitution. All values have working defaults except STEAM_API_KEY and
# FACEIT_API_KEY (each gates an optional panel that stays hidden until set).

# --- Steam Web API ----------------------------------------------------------
# Get one at https://steamcommunity.com/dev/apikey. Leave BLANK for now: the
# stack runs without it, but vanity-URL resolution and Steam identity hydration
# stay disabled until a key is provided.
STEAM_API_KEY=

# --- Leetify public API (keyless; key optional for higher rate limits) ------
# Powers the live Leetify panel on profiles. Defaults work out of the box.
LEETIFY_BASE_URL=https://api-public.cs-prod.leetify.com
LEETIFY_API_KEY=

# --- FACEIT Data API --------------------------------------------------------
# Powers the live FACEIT panel (skill level, ELO, lifetime stats). Get a FREE
# server-side key at https://developers.faceit.com (create an app -> API keys ->
# "server side"). Without it the FACEIT panel is simply hidden.
FACEIT_BASE_URL=https://open.faceit.com/data/v4
FACEIT_API_KEY=

# --- Postgres ---------------------------------------------------------------
POSTGRES_USER=cs2
# Local dev can keep 'cs2'. For ANY public deploy set a strong random value
# (e.g. openssl rand -hex 24) — the prod compose refuses to start without one.
POSTGRES_PASSWORD=cs2
POSTGRES_DB=cs2tracker

# --- Production single-box (docker-compose.prod.yml + Caddy) -----------------
# DOMAIN is the bare host Caddy serves TLS for (no scheme). SITE_URL is the full
# https origin (set in the Frontend section below). Example for both:
#   DOMAIN=steamcommunity.run
#   SITE_URL=https://steamcommunity.run
DOMAIN=localhost

# --- Backend (used when running services OUTSIDE docker) ---------------------
# Inside docker compose these are set per-service with the right hostnames.
# For a local run (go run ./cmd/api) point them at localhost:
#   DATABASE_URL=postgres://cs2:cs2@localhost:5432/cs2tracker?sslmode=disable
#   REDIS_URL=redis://localhost:6379/0
HTTP_ADDR=:8080
# Allowed browser origins (comma-separated). In production set to your real site
# origin, e.g. https://steamcommunity.run — only matters if the browser calls the
# backend directly (it normally doesn't; the frontend proxies server-side).
CORS_ORIGINS=http://localhost:3000
# Shared secret that locks the backend to the trusted frontend. STRONGLY
# recommended when the backend is on a public host (Fly.io): set the SAME random
# value here and as the frontend's INTERNAL_API_SECRET. When set, every route
# except /api/health requires an X-Internal-Token header, so randoms can't reach
# or scrape the API. Leave blank for local dev. Generate: openssl rand -hex 32
INTERNAL_API_SECRET=
DEMO_QUEUE_KEY=cs2:demos:parse
DEMO_WORK_DIR=/tmp/cs2
DELETE_RAW_DEMO=true
JOB_TIMEOUT=10m
# How many demos a single worker parses in parallel.
WORKER_CONCURRENCY=1
# --- Demo direct upload (object storage) ------------------------------------
# Set DEMO_GCS_BUCKET to a Google Cloud Storage bucket to let the browser upload
# .dem files straight to the bucket (bypassing Cloudflare's 100MB limit, so big
# demos work). Leave blank to fall back to through-server multipart (<=95MB).
# Setup (bucket + CORS + lifecycle + service-account roles): see docs/demo-parsing.md
DEMO_GCS_BUCKET=
# Path to a service-account JSON key for URL signing. Leave blank on GCE to sign
# keyless via the attached service account (needs roles/iam.serviceAccountTokenCreator).
DEMO_GCS_CREDENTIALS=
# Max demo size for the direct path, in MB.
DEMO_MAX_MB=600
# Signed upload-URL lifetime.
DEMO_URL_TTL=15m
CACHE_TTL=5m
# TTL for cached live third-party payloads (Leetify / FACEIT / steam-extras), so
# repeat profile views don't re-hit those APIs on every request.
EXTERNAL_CACHE_TTL=15m
# Per-client-IP API rate limit. RATE_LIMIT_RPS=0 disables it.
RATE_LIMIT_RPS=10
RATE_LIMIT_BURST=20

# --- Frontend ---------------------------------------------------------------
# Where the Next.js server reaches the backend (server-to-server).
#   docker compose: http://backend:8080
#   local dev:      http://localhost:8080
API_INTERNAL_URL=http://localhost:8080
# Public origin of the site, used for canonical/OpenGraph/sitemap/robots URLs.
# MUST be set for any public deploy or these default to http://localhost:3000.
#   e.g. https://steamcommunity.run  (no trailing slash)
SITE_URL=http://localhost:3000
