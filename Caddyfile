# Caddy reverse proxy for the single-box prod deploy.
# TLS is terminated here with a Cloudflare ORIGIN certificate (so Cloudflare's
# SSL/TLS mode can be "Full (strict)" with the orange-cloud proxy on). Browsers
# only ever see Cloudflare's edge cert; this cert secures Cloudflare <-> origin.
# DOMAIN is injected from the environment by docker-compose.prod.yml.
# The retired domain (steamcommunity.run) is NOT served here — a Cloudflare
# edge Redirect Rule 301s it to the apex, so it never reaches this origin.

{$DOMAIN}, www.{$DOMAIN} {
	encode zstd gzip

	# Cloudflare Origin Certificate (generated in the Cloudflare dashboard and
	# saved next to docker-compose.prod.yml as origin.pem / origin.key). It must
	# cover {$DOMAIN} AND *.{$DOMAIN} so the www host below is served too.
	tls /etc/caddy/origin.pem /etc/caddy/origin.key

	# Canonical host: send www -> apex so the site lives at one URL (SEO).
	@www host www.{$DOMAIN}
	redir @www https://{$DOMAIN}{uri} permanent

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		X-Frame-Options "SAMEORIGIN"
		Permissions-Policy "camera=(), microphone=(), geolocation=(), interest-cohort=()"
		# CSP is permissive on script/style ('unsafe-inline' — Next.js ships inline
		# bootstrap scripts and Tailwind inlines styles) and on https: images (Steam
		# avatar CDNs), but locks down object/base/frame-ancestors/form-action. The
		# app has no dangerouslySetInnerHTML sink, so this is defense-in-depth +
		# clickjacking protection. Tighten to nonces later if an HTML sink is added.
		# script-src/connect-src also allow Cloudflare Web Analytics: the beacon
		# loads from static.cloudflareinsights.com and reports to cloudflareinsights.com.
		# connect-src also allows liquipedia.net: pro-player photos resolve in the
		# browser (Liquipedia rate-limits datacenter IPs, so the VM can't).
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https://storage.googleapis.com https://*.storage.googleapis.com https://cloudflareinsights.com https://liquipedia.net; object-src 'none'; base-uri 'self'; frame-ancestors 'self'; form-action 'self'; upgrade-insecure-requests"
		-Server
	}

	# Everything goes to the Next.js frontend; it reaches the Go backend over the
	# internal Docker network. The backend is never exposed publicly.
	reverse_proxy frontend:3000
}
