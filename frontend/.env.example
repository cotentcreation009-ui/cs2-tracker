# Frontend env for LOCAL dev (copy to .env.local).
# Where the Next.js server reaches the Go backend (server-to-server fetches).
#   local dev:        http://localhost:8080
#   Vercel + Fly:     https://<your-app>.fly.dev
API_INTERNAL_URL=http://localhost:8080

# Public origin of the site — drives canonical / OpenGraph / sitemap / robots.
# MUST be set in production or these default to http://localhost:3000.
#   e.g. https://steamcommunity.run   (no trailing slash)
SITE_URL=http://localhost:3000

# Must match the backend's INTERNAL_API_SECRET. When set, the frontend sends it
# as X-Internal-Token on every backend call so a publicly-hosted (Fly.io) backend
# accepts only this trusted server. Leave blank for local dev.
INTERNAL_API_SECRET=

