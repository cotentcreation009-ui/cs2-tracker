# Frontend env for LOCAL dev (copy to .env.local).
# Where the Next.js server reaches the Go backend (server-to-server fetches).
API_INTERNAL_URL=http://localhost:8080

# Secret used to sign the "Sign in through Steam" session cookie (HMAC-SHA256).
# Optional in dev (a built-in fallback is used); REQUIRED in production — set it
# to a long random string. Generate one with: openssl rand -base64 32
# SESSION_SECRET=

# Public origin the browser uses, e.g. https://cs2tracker.example. Only needed
# when behind a proxy that rewrites Host (or the steamcommunity.<tld> mirror);
# in local dev it is derived from the request automatically.
# SITE_URL=
