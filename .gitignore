/backend/bin/
*.exe
*.test
*.out

# Node / Next
node_modules/
.next/
out/
npm-debug.log*
yarn-error.log*
*.tsbuildinfo

# Claude Code local settings
.claude/

# Editors / OS
.DS_Store
Thumbs.db
.idea/
*.swp
# .vscode/ is committed (shared tasks/launch/extensions); ignore only local user files
.vscode/*.log

# local build artifacts (parsedemo.exe etc.)
/bin/

